{
  "name": "agent-report-mcp",
  "version": "1.0.0",
  "description": "MCP tool for automatically summarizing AI Agent work and generating reports",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "agent-report-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "server": "npm run build && npm run start:server",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "agent",
    "report",
    "ai",
    "claude",
    "opencode"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "simple-git": "^3.32.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
